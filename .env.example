DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
DATABASE_URL=postgresql://wbd:wbd_dev@localhost:5433/wbd
TEST_DATABASE_URL=postgresql://wbd:wbd_dev@localhost:5433/wbd_test
BROKER_PORT=4000
WS_PROXY_PORT=4100
NEXT_PUBLIC_WS_PROXY_URL=ws://localhost:4100
DEV_USER_ID=dev-user

# GitHub private-repo clone auth — used by the container at boot
GITHUB_CLONE_TOKEN=
GITHUB_REPO_OWNER=appsolution-mw
GITHUB_REPO_NAME=website-builder-daytona
# Optional: clone a specific branch instead of the default. Useful for testing
# feature branches before merging. Defaults to main.
GITHUB_CLONE_BRANCH=main

# Daytona mode: 'cloud' uses the real SDK; 'fake' uses an in-process stub
DAYTONA_MODE=cloud

# Sandbox runtime selector. Overrides DAYTONA_MODE when set.
#   - daytona-cloud   real Daytona API (default if RUNTIME_MODE unset and DAYTONA_MODE=cloud)
#   - daytona-fake    in-process local broker for dev/tests
#   - hetzner-fake    multi-cloud runtime with FakeProvisioner (Phase H.1c+)
#   - hetzner-cloud   multi-cloud runtime with HetznerProvisioner (Phase H.1c+)
RUNTIME_MODE=

# === Sandbox runtime (worker-pool mode) ===
RUNTIME_MODE=worker-pool-local                  # 'daytona-fake' to keep old dev path
SANDBOX_IMAGE=wbd/sandbox:dev                   # local: ghcr.io/appsolution-mw/sandbox:latest in production
WORKER_AGENT_URL=http://127.0.0.1:4500          # local-dev override; production reads from DB
WORKER_AGENT_HMAC_SECRET=                       # 32-byte random hex; set the same on host and agent
WORKER_ID=local-1                               # only set in local-dev

# Agent runtime inside each sandbox.
#   - claude-code: existing Claude Code CLI path (default)
#   - openai-codex: OpenAI Codex SDK/CLI path
#   - openhands: local Python OpenHands bridge path
AGENT_RUNTIME=openhands

# Auth for Claude Code inside each sandbox.
# Preferred for this project: use OpenRouter's Anthropic-compatible gateway.
# Set OPENROUTER_API_KEY and leave ANTHROPIC_API_KEY empty; the runtime maps
# OPENROUTER_API_KEY to ANTHROPIC_API_KEY for Claude Code and sets
# ANTHROPIC_BASE_URL=https://openrouter.ai/api.
# If ANTHROPIC_API_KEY is set directly, it wins and is passed through as-is;
# clear ANTHROPIC_BASE_URL as well when using Anthropic directly.
# For OpenRouter spawns, the broker omits CLAUDE_CODE_OAUTH_TOKEN so the CLI
# uses the OpenRouter-backed ANTHROPIC_API_KEY instead.
#   - CLAUDE_CODE_OAUTH_TOKEN: long-lived token from `claude setup-token`,
#     bound to a Claude Pro/Max subscription. Personal use only.
#   - ANTHROPIC_API_KEY: standard pay-per-token API key from platform.claude.com.
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://openrouter.ai/api
OPENROUTER_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_REVIEWER_MODEL=claude-sonnet-4-6

# Optional hard limits for Claude Code subprocesses in each sandbox.
# Values are milliseconds; set to 0 to disable a given hard timeout.
CLAUDE_TURN_TIMEOUT_MS=3600000
CLAUDE_REVIEWER_TIMEOUT_MS=3600000

# Auth/config for AGENT_RUNTIME=openai-codex. CODEX_API_KEY wins, otherwise
# the broker falls back to OPENAI_API_KEY. Codex turn cost is currently
# reported as 0 because the SDK exposes token usage, not priced totals.
OPENAI_API_KEY=
CODEX_API_KEY=
CODEX_MODEL=gpt-5.5
CODEX_REVIEWER_MODEL=gpt-5.5
CODEX_REASONING_EFFORT=medium
CODEX_REVIEWER_REASONING_EFFORT=high
# Daytona/worker containers already isolate project execution. The default
# disables Codex's inner bwrap sandbox, which requires unprivileged user
# namespaces that many container hosts do not expose.
CODEX_SANDBOX_MODE=danger-full-access
CODEX_REVIEWER_SANDBOX_MODE=danger-full-access
CODEX_NETWORK_ACCESS=0

# Auth/config for AGENT_RUNTIME=openhands. The runtime uses OpenRouter model
# ids from the UI/session state when provided, otherwise these defaults.
OPENHANDS_MODEL=openrouter:qwen/qwen3-coder:free
OPENHANDS_REVIEWER_MODEL=openrouter:qwen/qwen3-coder:free
OPENHANDS_BASE_URL=https://openrouter.ai/api/v1
OPENHANDS_MAX_ITERATIONS=30
OPENHANDS_ENABLE_PUBLIC_SKILLS=0
# Optional generic LiteLLM-compatible overrides for OpenHands.
LLM_API_KEY=
LLM_BASE_URL=

# Optional defaults for the Vercel AI SDK runtime. This runtime uses the
# official AI SDK with a provider registry and can target OpenAI or Anthropic
# models via ids like `openai:gpt-5.2` or `anthropic:claude-sonnet-4-5`.
VERCEL_AI_MODEL=openai:gpt-5.5
VERCEL_AI_REVIEWER_MODEL=openai:gpt-5.5

