generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id
  email     String   @unique
  createdAt DateTime @default(now())
  projects  Project[]
}

model Project {
  id                   String        @id @default(cuid())
  ownerId              String
  owner                User          @relation(fields: [ownerId], references: [id])
  name                 String
  status               ProjectStatus @default(PROVISIONING)
  agentRuntime         AgentRuntime  @default(CLAUDE_CODE)
  desiredRuntime       AgentRuntime  @default(CLAUDE_CODE)
  runtimeSwitchStatus  RuntimeSwitchStatus @default(IDLE)
  runtimeGeneration    Int           @default(1)
  createdAt            DateTime      @default(now())
  lastActive           DateTime      @default(now())

  daytonaSandboxId     String?
  brokerUrl            String?
  brokerPreviewToken   String?
  previewUrl           String?
  provisioningError    String?

  sessions             Session[]
  sessionRuntimeStates SessionRuntimeState[]
  messages             Message[]
  tokenUsages          TokenUsage[]

  @@index([ownerId])
}

enum ProjectStatus {
  PROVISIONING
  RUNNING
  PAUSED
  ARCHIVED
  DESTROYED
}

model Session {
  id               String    @id @default(cuid())
  projectId        String
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title            String    @default("untitled")
  defaultRuntime   AgentRuntime @default(CLAUDE_CODE)
  createdAt        DateTime  @default(now())
  lastMessageAt    DateTime  @default(now())
  messages         Message[]
  runtimeStates    SessionRuntimeState[]
}

model Message {
  id        String       @id @default(cuid())
  projectId String
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sessionId String?
  session   Session?     @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  turnId    String?
  agentId   String?
  runtime   AgentRuntime?
  provider  String?
  modelId   String?
  role      MessageRole
  content   String
  createdAt DateTime     @default(now())

  @@index([projectId, createdAt])
  @@index([sessionId, createdAt])
}

model TokenUsage {
  id                       String          @id @default(cuid())
  projectId                String
  project                  Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  turnId                   String
  label                    TokenUsageLabel
  runtime                  AgentRuntime?
  provider                 String?
  modelId                  String?
  durationMs               Int             @default(0)
  inputTokens              Int             @default(0)
  outputTokens             Int             @default(0)
  cacheCreationInputTokens Int             @default(0)
  cacheReadInputTokens     Int             @default(0)
  totalTokens              Int             @default(0)
  webSearchRequests        Int             @default(0)
  webFetchRequests         Int             @default(0)
  costUsd                  Decimal         @default(0) @db.Decimal(18, 9)
  exitCode                 Int             @default(0)
  serviceTier              String?
  inferenceGeo             String?
  rawUsage                 Json?
  modelUsage               Json?
  createdAt                DateTime        @default(now())

  @@unique([projectId, turnId, label])
  @@index([projectId, createdAt])
  @@index([projectId, turnId])
}

model SessionRuntimeState {
  id                String       @id @default(cuid())
  projectId         String
  project           Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sessionId         String
  session           Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  runtime           AgentRuntime
  providerSessionId String
  modelId           String?
  resumeState       Json?
  lastUsedAt        DateTime     @default(now())
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([sessionId, runtime])
  @@unique([runtime, providerSessionId])
  @@index([projectId, sessionId])
}

enum TokenUsageLabel {
  CODER
  REVIEWER
  TURN
}

enum MessageRole {
  USER
  AGENT
  SYSTEM
}

enum AgentRuntime {
  CLAUDE_CODE
  OPENAI_CODEX
  VERCEL_AI
}

enum RuntimeSwitchStatus {
  IDLE
  PENDING
  SWITCHING
  FAILED
}

enum WorkerStatus {
  PROVISIONING
  READY
  DRAINING
  DECOMMISSIONED
  OFFLINE
}

enum SandboxLifecycleStatus {
  SPAWNING
  RUNNING
  PAUSED
  DESTROYED
}

model Worker {
  id                String          @id @default(cuid())
  tailscaleHostname String          @unique
  tailscaleIp       String
  provider          String
  providerVmId      String
  region            String
  capacity          Int
  status            WorkerStatus    @default(PROVISIONING)
  lastHeartbeatAt   DateTime?
  createdAt         DateTime        @default(now())
  decommissionedAt  DateTime?
  sandboxes         WorkerSandbox[]

  @@index([status])
  @@index([provider, region])
}

model WorkerSandbox {
  id             String                 @id @default(cuid())
  workerId       String
  worker         Worker                 @relation(fields: [workerId], references: [id])
  projectId      String                 @unique
  containerId    String
  brokerPort     Int
  previewPort    Int
  status         SandboxLifecycleStatus @default(SPAWNING)
  createdAt      DateTime               @default(now())
  pausedAt       DateTime?
  lastActivityAt DateTime               @default(now())

  @@index([workerId])
  @@index([status])
}

model SandboxToken {
  id        String   @id @default(cuid())
  sandboxId String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}
