generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id
  email     String   @unique
  createdAt DateTime @default(now())
  projects  Project[]
}

model Project {
  id                   String        @id @default(cuid())
  ownerId              String
  owner                User          @relation(fields: [ownerId], references: [id])
  name                 String
  status               ProjectStatus @default(PROVISIONING)
  createdAt            DateTime      @default(now())
  lastActive           DateTime      @default(now())

  daytonaSandboxId     String?
  brokerUrl            String?
  brokerPreviewToken   String?
  previewUrl           String?
  provisioningError    String?

  sessions             Session[]
  messages             Message[]
  tokenUsages          TokenUsage[]

  @@index([ownerId])
}

enum ProjectStatus {
  PROVISIONING
  RUNNING
  PAUSED
  ARCHIVED
  DESTROYED
}

model Session {
  id              String    @id @default(cuid())
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  claudeSessionId String    @unique
  title           String    @default("untitled")
  createdAt       DateTime  @default(now())
  lastMessageAt   DateTime  @default(now())
  messages        Message[]
}

model Message {
  id        String      @id @default(cuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sessionId String?
  session   Session?    @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  turnId    String?
  agentId   String?
  role      MessageRole
  content   String
  createdAt DateTime    @default(now())

  @@index([projectId, createdAt])
  @@index([sessionId, createdAt])
}

model TokenUsage {
  id                       String          @id @default(cuid())
  projectId                String
  project                  Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  turnId                   String
  label                    TokenUsageLabel
  durationMs               Int             @default(0)
  inputTokens              Int             @default(0)
  outputTokens             Int             @default(0)
  cacheCreationInputTokens Int             @default(0)
  cacheReadInputTokens     Int             @default(0)
  totalTokens              Int             @default(0)
  webSearchRequests        Int             @default(0)
  webFetchRequests         Int             @default(0)
  costUsd                  Decimal         @default(0) @db.Decimal(18, 9)
  exitCode                 Int             @default(0)
  serviceTier              String?
  inferenceGeo             String?
  rawUsage                 Json?
  modelUsage               Json?
  createdAt                DateTime        @default(now())

  @@unique([projectId, turnId, label])
  @@index([projectId, createdAt])
  @@index([projectId, turnId])
}

enum TokenUsageLabel {
  CODER
  REVIEWER
  TURN
}

enum MessageRole {
  USER
  AGENT
  SYSTEM
}
